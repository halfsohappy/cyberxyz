---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  {
    id: '01',
    slug: 'bodice',
    name: 'vector-bodice',
    description: 'parametric sewing pattern generator',
    detail: 'input 8 measurements ‚Üí SVG bodice block',
    status: 'ONLINE',
    href: '/tools/bodice',
  },
